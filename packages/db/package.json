{
  "name": "@recipes/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./zod": {
      "types": "./src/zod.ts",
      "default": "./src/zod.ts"
    },
    "./enums": {
      "types": "./src/enums.ts",
      "default": "./src/enums.ts"
    }
  },
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:migrate": "dotenv -e ../../apps/api/.env -- drizzle-kit migrate",
    "db:studio": "dotenv -e ../../apps/api/.env -- drizzle-kit studio",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.30.0",
    "drizzle-zod": "^0.5.0",
    "postgres": "^3.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "dotenv-cli": "^7.4.0",
    "drizzle-kit": "^0.21.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0"
  }
}
